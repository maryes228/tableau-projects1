      <column caption='SalesTrend' datatype='real' name='[Calculation_0887355350708224]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Sales]) - LOOKUP(SUM([Sales]), -1)'>
          <table-calc ordering-type='Rows' />
